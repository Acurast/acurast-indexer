  "query": "\n        SELECT sv.spec_version, sv.block_number, b.hash as block_hash\n        FROM spec_versions sv\n        JOIN blocks b ON sv.block_number = b.block_number\n        WHERE sv.metadata IS NULL\n        ORDER BY sv.spec_version ASC\n        ",
